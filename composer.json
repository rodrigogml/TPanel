{
  "name": "rodrigogml/tpanel",
  "description": "TPanel / Turin Panel server monitoring and administration portal.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4"
  },
  "autoload": {
    "psr-4": {
      "TPanel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TPanel\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": [
      "find public src tests -name '*.php' -print -exec php -l {} \\;"
    ],
    "test": [
      "vendor/bin/phpunit --configuration phpunit.xml"
    ],
    "check": [
      "@composer validate --strict",
      "@composer lint",
      "@composer test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phpunit/phpunit": "^12"
  }
}
