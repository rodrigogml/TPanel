#!/bin/sh
set -eu

usage() {
    echo "usage: docker-container-status <containerName>" >&2
    exit 64
}

[ "$#" -eq 1 ] || usage
container_name="$1"

case "$container_name" in
    [A-Za-z0-9]*)
        ;;
    *)
        echo "invalid containerName" >&2
        exit 64
        ;;
esac

case "$container_name" in
    *[!A-Za-z0-9_.-]*)
        echo "invalid containerName" >&2
        exit 64
        ;;
esac

if [ "${#container_name}" -gt 128 ]; then
    echo "invalid containerName length" >&2
    exit 64
fi

exec /usr/bin/docker inspect --format '{{.Name}} {{.State.Status}} {{.State.Health.Status}}' "$container_name"
