#!/bin/sh
set -eu

usage() {
    echo "usage: service-reload <serviceName>" >&2
    exit 64
}

[ "$#" -eq 1 ] || usage
service_name="$1"

case "$service_name" in
    ''|*[!A-Za-z0-9@_.-]*)
        echo "invalid serviceName" >&2
        exit 64
        ;;
esac

if [ "${#service_name}" -gt 120 ]; then
    echo "invalid serviceName length" >&2
    exit 64
fi

exec /usr/bin/systemctl reload "$service_name"
