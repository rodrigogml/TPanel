#!/bin/sh
set -eu

usage() {
    echo "usage: timer-status <timerName>" >&2
    exit 64
}

[ "$#" -eq 1 ] || usage
timer_name="$1"

case "$timer_name" in
    *.timer)
        ;;
    *)
        echo "invalid timerName suffix" >&2
        exit 64
        ;;
esac

case "$timer_name" in
    ''|*[!A-Za-z0-9@_.-]*)
        echo "invalid timerName" >&2
        exit 64
        ;;
esac

if [ "${#timer_name}" -gt 160 ]; then
    echo "invalid timerName length" >&2
    exit 64
fi

exec /usr/bin/systemctl show "$timer_name" --no-pager --property=Id,LoadState,ActiveState,SubState,NextElapseUSecRealtime,LastTriggerUSec
